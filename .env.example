# ─────────────────────────────────────────────────────────────────────────────
#  Configuración de entorno — copia este archivo a .env y rellena lo que uses.
#  Solo DATABASE_URL es obligatoria. Todo lo demás es opcional / por integración.
#  NUNCA subas tu .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (OBLIGATORIA) ──────────────────────────────────────────────
# PostgreSQL. En la nube (Neon) suele requerir SSL (?sslmode=require).
# Para un Postgres LOCAL sin TLS, usa ?sslmode=disable.
DATABASE_URL="postgresql://app:app@localhost:5432/app?sslmode=disable"

# ── Acceso / seguridad (opcional) ────────────────────────────────────────────
# La app NO tiene login por defecto (pensada para self-host detrás de tu propia red/proxy).
# Si defines APP_PASSWORD, TODA la instancia queda detrás de una sola contraseña compartida
# (ideal para una herramienta interna). Déjalo vacío para dejarla abierta (p.ej. una demo).
APP_PASSWORD=""

# ── Marca / white-label ──────────────────────────────────────────────────────
# Defaults que se usan si NO se configura la marca en el wizard /setup (la DB manda sobre esto).
BRAND_NAME="Taller 3D"
BRAND_SHORT_NAME="Taller 3D"
BRAND_DESCRIPTION="Catálogo, costeo y publicación para impresión 3D."
BRAND_TAGLINE="Catálogo y costeo de impresión 3D"
BRAND_LOGO_URL=""
BRAND_ML_SELLER_NAME="Taller 3D"
BRAND_THEME_COLOR="#0f172a"
BRAND_COLOR_PRIMARY="#0891b2"
BRAND_COLOR_ACCENT="#22d3ee"
BRAND_COLOR_BG_DARK="#020617"
BRAND_COLOR_BG_LIGHT="#f1f5f9"

# URL pública de la app (sin barra final). Se usa para armar enlaces absolutos (p.ej. para que ML
# descargue imágenes). En local: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Asistente de marca con IA (opcional, BYOK) ───────────────────────────────
# El wizard /setup puede generar nombre/paleta (texto) y logo (imagen) con IA.
# Funciona también pegando el token directamente en el wizard (uso transitorio, no se guarda).
OPENROUTER_API_KEY=""          # texto (también usado por la visión de IP/descripciones)
VISION_MODEL="openai/gpt-4o-mini"
OPENAI_API_KEY=""              # texto y/o imágenes (gpt-image-1)
ANTHROPIC_API_KEY=""           # texto (Claude)
FAL_KEY=""                     # imágenes (logo, FLUX en fal.ai)

# ── Mercado Libre (opcional) ─────────────────────────────────────────────────
ML_APP_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI="http://localhost:3000/api/ml/callback"
ML_NOTIFICATIONS_URL="http://localhost:3000/api/ml/callbacknotice"

# ── Bot / automatización (opcional) ──────────────────────────────────────────
# Clave para que el bot (Hermes/openclaw) llame los endpoints /api/bot/* (header x-bot-key).
BOT_API_KEY=""
# Secreto para disparos por cron (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=""
# Alertas opcionales por Telegram.
TELEGRAM_ALERT_TOKEN=""
TELEGRAM_ALERT_CHATS=""

# ── Almacenamiento de imágenes (opcional) ────────────────────────────────────
# Sin token: se guardan en /public (ideal para self-host con volumen). Con token: Vercel Blob.
BLOB_READ_WRITE_TOKEN=""

# ── Otros (opcional) ─────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=""           # scraping de fichas (importación)
# TENANT_ID="default"          # self-host: un solo negocio (lo usa la costura de tenant)
# SEED_ON_START="0"            # 1 = sembrar datos de ejemplo al arrancar el contenedor
# SKIP_SETUP="1"               # 1 = NO forzar el asistente /setup (para despliegues ya configurados;
#                              #     define la marca por BRAND_* y omite el wizard)
